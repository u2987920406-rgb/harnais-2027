{
  "name": "harnais-2027",
  "version": "0.1.0",
  "description": "Harnais agentique du futur — cortex cognitif continu, graphe de connaissance, emergence",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "think": "tsx src/index.ts --think",
    "sleep": "tsx src/index.ts --sleep",
    "ui": "tsx src/index.ts --ui",
    "ui:dev": "tsx src/index.ts --ui 7891",
    "test": "tsx --test test/*.test.ts",
    "smoke": "tsx test/live/ollama.smoke.ts",
    "smoke:workflow": "tsx test/live/workflow.smoke.ts",
    "smoke:verifier": "tsx test/live/verifier.smoke.ts",
    "smoke:cortex": "tsx test/live/cortex.smoke.ts",
    "smoke:scenario": "tsx test/live/scenario.smoke.ts",
    "smoke:scenario-live": "tsx test/live/scenario-live.smoke.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}